{
  "name": "structured-world-model",
  "version": "0.1.0",
  "description": "Agentic software that turns anything you throw at it into structured world models",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "swm": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "tsx test/run-unit.ts",
    "test:e2e": "tsx test/proof.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "world-model",
    "agentic",
    "structured-data",
    "knowledge-extraction"
  ],
  "author": "Motherlabs",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
